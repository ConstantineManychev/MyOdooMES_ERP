<odoo>
    <data noupdate="1">
        <record id="ir_cron_sync_maintainx_tasks" model="ir.cron">
            <field name="name">MES: Tasks Loading from MaintainX</field>
            <field name="model_id" ref="model_mes_task"/>
            <field name="state">code</field>
            <field name="code">model.load_tasks_from_maintainx()</field>
            <field name="user_id" ref="base.user_root"/>
            <field name="interval_number">1</field>
            <field name="interval_type">hours</field>
            <field name="numbercall">-1</field>
            <field name="doall" eval="False"/>
            <field name="active" eval="False"/> 
        </record>

        <record id="ir_cron_generate_flat_downtimes" model="ir.cron">
            <field name="name">MES: Generate Flat Downtime Schedule</field>
            <field name="model_id" ref="model_mes_planned_downtime"/>
            <field name="state">code</field>
            <field name="code">model.generate_flat_schedule_for_week(14)</field>
            <field name="user_id" ref="base.user_root"/>
            <field name="interval_number">1</field>
            <field name="interval_type">days</field>
            <field name="numbercall">-1</field>
            <field name="nextcall" eval="(DateTime.now() + relativedelta(days=1)).strftime('%Y-%m-%d 00:00:00')"/>
        </record>

        <record id="ir_cron_update_machine_metrics" model="ir.cron">
            <field name="name">MES: Update Realtime Machine Metrics</field>
            <field name="model_id" ref="mrp.model_mrp_workcenter"/>
            <field name="state">code</field>
            <field name="code">model.cron_update_realtime_metrics()</field>
            <field name="user_id" ref="base.user_root"/>
            <field name="interval_number">1</field>
            <field name="interval_type">minutes</field>
            <field name="numbercall">-1</field>
            <field name="active" eval="True"/>
        </record>

        <record id="ir_cron_manage_shifts" model="ir.cron">
            <field name="name">MES: Manage Machine Shifts</field>
            <field name="model_id" ref="model_mes_machine_performance"/>
            <field name="state">code</field>
            <field name="code">model.cron_manage_shifts()</field>
            <field name="user_id" ref="base.user_root"/>
            <field name="interval_number">10</field>
            <field name="interval_type">minutes</field>
            <field name="numbercall">-1</field>
            <field name="active" eval="True"/>
        </record>
    </data>
</odoo>