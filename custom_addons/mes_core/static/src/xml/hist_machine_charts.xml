<?xml version="1.0" encoding="UTF-8"?>
<templates xml:space="preserve">
    <t t-name="mes_core.HistMachineChartsTmpl" owl="1">
        <div class="mt-4">
            <div t-if="state.error" class="alert alert-danger" role="alert">
                <t t-esc="state.error"/>
            </div>
            
            <div t-else="" class="d-flex flex-column gap-3">
                <div class="bg-view border rounded p-3 shadow-sm position-relative">
                    <div class="position-absolute top-0 end-0 m-2 d-flex gap-2 z-index-1">
                        <input type="range" class="form-range" min="1" max="20" step="0.5" t-model="state.zoomLevel" t-on-input="applyZoomAndPan" title="Zoom"/>
                        <input type="range" class="form-range" min="0" max="100" step="1" t-model="state.panOffset" t-on-input="applyZoomAndPan" title="Pan"/>
                    </div>
                    
                    <div t-on-wheel="onWheelZoom">
                        <canvas t-ref="chartCanvas" height="400"></canvas>
                    </div>
                </div>

                <div class="bg-view border rounded p-3 shadow-sm overflow-hidden">
                    <div class="mes-timeline-wrapper position-relative" style="height: 30px; background-color: #f8f9fa; border-radius: 4px;">
                        <t t-foreach="state.visibleTimeline" t-as="block" t-key="block_index">
                            <div class="position-absolute h-100 border-end border-white"
                                 t-att-style="`left: ${block.leftPct}%; width: ${block.widthPct}%; background-color: ${block.color};`"
                                 t-att-title="`${block.name} (${block.durationMin} min)`"
                                 data-bs-toggle="tooltip" data-bs-placement="top">
                            </div>
                        </t>
                    </div>
                </div>
            </div>
        </div>
    </t>
</templates>