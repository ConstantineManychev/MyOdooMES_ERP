<?xml version="1.0" encoding="utf-8"?>
<odoo>

    <record id="view_mes_reject_report_tree" model="ir.ui.view">
        <field name="name">mes.reject.report.line.tree</field>
        <field name="model">mes.reject.report.line</field>
        <field name="arch" type="xml">
            <tree string="Rejects List" create="false" edit="false" delete="false" default_order="qty desc">
                <field name="row_group_label"/>
                <field name="col_group_label"/>
                <field name="qty" sum="Total Quantity"/>
                <field name="qty_per_hour" avg="Avg per Hour"/>
            </tree>
        </field>
    </record>

    <record id="view_mes_reject_report_pivot" model="ir.ui.view">
        <field name="name">mes.reject.report.line.pivot</field>
        <field name="model">mes.reject.report.line</field>
        <field name="arch" type="xml">
            <pivot string="Rejects Matrix" disable_linking="True">
                <field name="row_group_label" type="row"/>
                <field name="col_group_label" type="col"/>
                <field name="qty" type="measure"/>
                <field name="qty_per_hour" type="measure"/>
            </pivot>
        </field>
    </record>

    <record id="view_mes_reject_wizard_form" model="ir.ui.view">
        <field name="name">mes.reject.report.wizard.form</field>
        <field name="model">mes.reject.report.wizard</field>
        <field name="inherit_id" ref="mes_core.view_mes_report_base_form"/>
        <field name="mode">primary</field>
        <field name="arch" type="xml">
            
            <xpath expr="//group[@name='skd_filters']" position="inside">
                <label for="cnt_ids" string="Reject Counts"/>
                <div class="o_row">
                    <field name="cnt_filter_type" nolabel="1"/>
                    <field name="cnt_ids" widget="many2many_tags" nolabel="1" placeholder="All Data"/>
                </div>
            </xpath>
            
            <xpath expr="//group[@name='row_group']" position="inside">
                <field name="row_by_cnt"/>
                <field name="row_by_is_mod"/>
                <field name="row_by_wheel"/>
                <field name="row_by_mod"/>
            </xpath>
            
            <xpath expr="//group[@name='col_group']" position="inside">
                <field name="col_by_cnt"/>
                <field name="col_by_is_mod"/>
                <field name="col_by_wheel"/>
                <field name="col_by_mod"/>
            </xpath>
            
            <xpath expr="//page[@name='measures_page']" position="inside">
                <group>
                    <field name="show_qty"/>
                    <field name="show_qty_per_hour"/>
                </group>
            </xpath>

        </field>
    </record>

    <record id="action_mes_reject_wizard" model="ir.actions.act_window">
        <field name="name">Reject Matrix Builder</field>
        <field name="res_model">mes.reject.report.wizard</field>
        <field name="view_mode">form</field>
        <field name="target">new</field>
    </record>

</odoo>