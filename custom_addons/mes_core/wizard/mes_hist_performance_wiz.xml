<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <record id="view_mes_hist_performance_wiz_form" model="ir.ui.view">
        <field name="name">mes.hist.performance.wiz.form</field>
        <field name="model">mes.hist.performance.wiz</field>
        <field name="arch" type="xml">
            <form string="Historical Shift Processing">
                <sheet>
                    <group>
                        <group>
                            <field name="start_date"/>
                            <field name="end_date"/>
                        </group>
                        <group>
                            <field name="machine_ids" widget="many2many_tags" options="{'no_create': True}"/>
                        </group>
                    </group>
                </sheet>
                <footer>
                    <button name="action_generate" string="Generate Documents" type="object" class="btn-primary"/>
                    <button string="Cancel" class="btn-secondary" special="cancel"/>
                </footer>
            </form>
        </field>
    </record>

    <record id="action_mes_hist_performance_wiz" model="ir.actions.act_window">
        <field name="name">Historical Shift Processing</field>
        <field name="res_model">mes.hist.performance.wiz</field>
        <field name="view_mode">form</field>
        <field name="target">new</field>
    </record>

    <menuitem id="menu_mes_tools" name="Tools" parent="mes_core.menu_mes_root" sequence="99"/>
    <menuitem id="menu_mes_hist_performance" name="Historical Shift Generator" parent="menu_mes_tools" action="action_mes_hist_performance_wiz" sequence="10"/>
</odoo>